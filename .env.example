# --- ms-seguimiento standalone ---
# Puerto host donde se expone la API (el contenedor escucha en 8083)
APP_PORT=8083
# Puerto host de PostgreSQL
DB_PORT=5432
# PostgreSQL: la BD y el usuario se crean automaticamente con estos valores
DB_NAME=spsrt_seguimiento
DB_USER=spsrt_seguimiento_user
DB_PASSWORD=spsrt_seguimiento_pwd
# JWT: mismo secreto que el resto del stack para validar tokens reales
JWT_SECRET=cambiar-esta-clave-en-produccion-minimo-32-bytes-aleatorios
